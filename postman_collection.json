{
  "info": {
    "name": "Chatter-Box API",
    "description": "Real-time room-based messaging backend API with WebSocket support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "room_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "message_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has status field', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('WebSocket server!');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check if server is running"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('access_token', jsonData.accessToken);",
                  "pm.environment.set('user_id', jsonData.user.id);",
                  "pm.test('Response has accessToken', function () {",
                  "    pm.expect(jsonData).to.have.property('accessToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"john_doe\""
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user/createUser",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "createUser"]
            },
            "description": "Create a new user with username. Send raw username string in body."
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user/getUser/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "getUser", "{{user_id}}"]
            },
            "description": "Get user details by ID"
          }
        }
      ]
    },
    {
      "name": "Room",
      "item": [
        {
          "name": "Create Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('room_id', jsonData.room.id);",
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"general\""
            },
            "url": {
              "raw": "{{base_url}}/api/v1/room/create-room",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "room", "create-room"]
            },
            "description": "Create a new room with a name. Send raw room name string in body."
          }
        },
        {
          "name": "Join Room",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"general\""
            },
            "url": {
              "raw": "{{base_url}}/api/v1/room/join-room",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "room", "join-room"]
            },
            "description": "Join an existing room by name"
          }
        },
        {
          "name": "Leave Room",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"general\""
            },
            "url": {
              "raw": "{{base_url}}/api/v1/room/leave-room",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "room", "leave-room"]
            },
            "description": "Leave a room by name"
          }
        }
      ]
    },
    {
      "name": "Message",
      "item": [
        {
          "name": "Send Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('message_id', jsonData.message.id);",
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"text\":\"Hello everyone!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/message/send-message",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "message", "send-message"]
            },
            "description": "Send a message to the database"
          }
        },
        {
          "name": "Update Message",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"text\":\"Updated message text\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/message/update-message/{{message_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "message", "update-message", "{{message_id}}"]
            },
            "description": "Update an existing message by ID"
          }
        },
        {
          "name": "Send Reaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"emoji\":\"HAPPY\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/message/send-reaction/{{message_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "message", "send-reaction", "{{message_id}}"]
            },
            "description": "Send a reaction to a message. Valid emojis: HAPPY, FUNNY, PARTY, LIKE, HEAT"
          }
        },
        {
          "name": "Get Message History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/message/history/{{room_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "message", "history", "{{room_id}}"]
            },
            "description": "Fetch all messages and reactions for a room"
          }
        }
      ]
    }
  ]
}
